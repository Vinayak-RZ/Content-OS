# PostgreSQL (Supabase) — enable pgvector in dashboard: Database → Extensions → vector
# Supabase → Connect → ORMs → copy pooler URLs (replace PASSWORD)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AES-256-GCM user API keys — MUST be exactly 64 hex chars: openssl rand -hex 32
ENCRYPTION_KEY=""

# Embeddings — knowledge chunks / discovery ranking (server-side, not user draft keys).
OPENAI_API_KEY=""

# Protects cron routes — omit until Phase 3 cron is wired.
CRON_SECRET=""

# Email (Phase 7)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="digest@yourdomain.com"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional discovery helpers
GITHUB_TOKEN=""
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
