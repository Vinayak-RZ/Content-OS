# PostgreSQL (Supabase) — enable pgvector in dashboard: Database → Extensions → vector
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AES-256 key — 32 bytes hex: openssl rand -hex 32
ENCRYPTION_KEY=""

# Embeddings only (not generation)
OPENAI_API_KEY=""

# Cron protection
CRON_SECRET=""

# Email (Phase 7)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="digest@yourdomain.com"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional discovery helpers
GITHUB_TOKEN=""
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
