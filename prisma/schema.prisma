generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  displayName     String
  timezone        String   @default("Asia/Kolkata")
  tavilyApiKey    String?
  firecrawlApiKey String?
  openrouterKey   String?
  nvidiaKey       String?
  openaiKey       String?
  draftProvider   String? // openrouter | nvidia | openai
  draftModelId    String?
  personaType        String?  // student | founder | engineer | content_creator | finance | other
  personaCustom      String?  @db.VarChar(500)
  onboardingCompletedAt DateTime?
  emailDigest     Boolean  @default(true)
  sourceConfig    Json?
  bufferApiKey           String?
  bufferOrganizationId   String?
  bufferLastSyncAt       DateTime?
  bufferLastSyncError    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trends            Trend[]
  drafts            Draft[]
  knowledgeChunks   KnowledgeChunk[]
  knowledgeFiles    KnowledgeFile[]
  topicEngagements  TopicEngagement[]
  cronLogs          CronLog[]
  discoveryRuns     DiscoveryRun[]
  usageCounters     UsageCounter[]
  blogPosts         BlogPost[]
  bufferChannels    BufferChannel[]
  socialPosts       SocialPost[]
}

model UsageCounter {
  userId    String
  kind      String // generate_hour | discover_day
  windowKey String // UTC hour key YYYY-MM-DDTHH or day key YYYY-MM-DD
  count     Int     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, kind, windowKey])
  @@index([userId, kind])
}

model Trend {
  id               String    @id @default(uuid())
  userId           String
  title            String
  source           String
  url              String
  urlHash          String
  summary          String
  trendScore       Float
  finalScore       Float
  tags             String[]
  sourceType       String
  pipeline         String   @default("signals") // signals | studio
  discoveredAt     DateTime @default(now())
  expiresAt        DateTime
  feedbackStatus   String?   // null | 'saved' | 'dismissed'
  feedbackAt       DateTime?
  discoveryBatchId String?
  savedUntil       DateTime?

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  drafts            Draft[]
  topicEngagements    TopicEngagement[]
  discoveryRunTopics  DiscoveryRunTopic[]

  @@index([userId, urlHash])
  @@index([userId, discoveredAt])
  @@index([userId, feedbackStatus])
  @@index([userId, discoveryBatchId])
  @@index([userId, pipeline, discoveredAt])
}

model Draft {
  id              String   @id @default(uuid())
  userId          String
  trendId         String?
  topicTitle      String
  currentContent  String   @db.Text
  hookVariants    String[]
  ctaVariants     String[]
  selectedHook    Int      @default(0)
  selectedCta     Int      @default(0)
  revisionHistory Json     @default("[]")
  xThreadParts    String[] @default([])
  sources         String[]
  pipeline        String   @default("signals")
  status          String   @default("draft")
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  trend            Trend?            @relation(fields: [trendId], references: [id], onDelete: SetNull)
  topicEngagements TopicEngagement[]
  socialPosts      SocialPost[]
}

model KnowledgeFile {
  id          String   @id @default(uuid())
  userId      String
  slug        String
  fileName    String
  displayName String
  role        String // style | narrative | technical | brand | general
  sortOrder   Int      @default(0)
  isSystem    Boolean  @default(false)
  content     String   @db.Text
  fileVersion Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fileName])
  @@unique([userId, slug])
  @@index([userId, role])
}

model KnowledgeChunk {
  id          String                       @id @default(uuid())
  userId      String
  fileName    String
  chunkText   String                       @db.Text
  embedding   Unsupported("vector(1536)")?
  chunkIndex  Int
  fileVersion Int                          @default(1)
  updatedAt   DateTime                     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, fileName])
}

model TopicEngagement {
  id        String                       @id @default(uuid())
  userId    String
  trendId   String?
  draftId   String?
  urlHash   String?
  topicTitle String
  topicEmbedding Unsupported("vector(1536)")?
  status    String
  selectedAt DateTime                    @default(now())
  publishedAt DateTime?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trend Trend? @relation(fields: [trendId], references: [id], onDelete: SetNull)
  draft Draft? @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([userId, urlHash])
  @@index([userId, status])
}

model CronLog {
  id              String   @id @default(uuid())
  userId          String
  runAt           DateTime @default(now())
  success         Boolean
  sourceCounts    Json
  totalDiscovered Int
  errorMessage    String?
  durationMs      Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, runAt])
}

model DiscoveryRun {
  id              String   @id @default(uuid())
  userId          String
  batchId         String
  pipeline        String   @default("signals")
  runAt           DateTime @default(now())
  success         Boolean  @default(true)
  sourceCounts    Json
  totalDiscovered Int
  newStored       Int
  carriedOver     Int
  durationMs      Int
  errorMessage    String?

  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics DiscoveryRunTopic[]

  @@unique([userId, batchId])
  @@index([userId, runAt])
}

model BlogPost {
  id              String   @id @default(uuid())
  userId          String
  title           String
  currentContent  String   @db.Text
  sources         String[]
  sourceTexts     Json     @default("[]")
  readTimeMinutes Int      @default(5)
  revisionHistory Json     @default("[]")
  status          String   @default("draft")
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
}

model DiscoveryRunTopic {
  id         String  @id @default(uuid())
  runId      String
  trendId    String?
  topicTitle String
  finalScore Float
  source     String?
  role       String // new | carried

  run   DiscoveryRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  trend Trend?       @relation(fields: [trendId], references: [id], onDelete: SetNull)

  @@index([runId])
}

model BufferChannel {
  id              String   @id @default(uuid())
  userId          String
  bufferChannelId String
  organizationId  String
  service         String // linkedin | twitter | ...
  name            String
  displayName     String?
  avatar          String?
  isQueuePaused   Boolean  @default(false)
  lastSyncedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialPosts SocialPost[]

  @@unique([userId, bufferChannelId])
  @@index([userId, service])
}

model SocialPost {
  id               String    @id @default(uuid())
  userId           String
  bufferPostId     String
  channelId        String
  draftId          String?
  text             String    @db.Text
  status           String
  publishedAt      DateTime?
  scheduledAt      DateTime?
  metricsUpdatedAt DateTime?
  metrics          Json      @default("[]")
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    BufferChannel              @relation(fields: [channelId], references: [id], onDelete: Cascade)
  draft      Draft?                     @relation(fields: [draftId], references: [id], onDelete: SetNull)
  metricSnapshots SocialPostMetricSnapshot[]

  @@unique([userId, bufferPostId])
  @@index([userId, publishedAt])
  @@index([userId, status])
}

model SocialPostMetricSnapshot {
  id           String   @id @default(uuid())
  socialPostId String
  type         String
  name         String
  value        Float
  unit         String
  recordedAt   DateTime @default(now())

  socialPost SocialPost @relation(fields: [socialPostId], references: [id], onDelete: Cascade)

  @@index([socialPostId, type, recordedAt])
}
